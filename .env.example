# SkillOS Agent Runtime — Environment Variables
# Copy this file to .env and fill in your keys.

# --- Qwen via OpenRouter (free tier available) ---
# Get your free API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here

# --- Gemini via Google AI ---
# Get your API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: Override the default model
# QWEN_MODEL=qwen/qwen3-4b:free

# Optional: Set max turns for agent execution
# QWEN_MAX_TURNS=10

# Optional: Enable debug mode for verbose output
# QWEN_DEBUG=false
