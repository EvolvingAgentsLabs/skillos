# SkillOS Agent Runtime — Environment Variables
# Copy this file to .env and fill in your keys.

# --- Qwen via OpenRouter (free tier available) ---
# Get your free API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here

# --- Gemini via Google AI ---
# Get your API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: Override the default model
# QWEN_MODEL=qwen/qwen3-4b:free

# Optional: Set max turns for agent execution
# QWEN_MAX_TURNS=10

# Optional: Enable debug mode for verbose output
# QWEN_DEBUG=false

# --- Gemma 4 via Ollama (local or Colab Pinggy tunnel) ---
# No API key needed for local Ollama. Set OLLAMA_BASE_URL for remote tunnel.
# OLLAMA_BASE_URL=https://xxx.a.pinggy.link/v1
# OLLAMA_API_KEY=ollama
# GEMMA_MODEL=gemma4
# Available: gemma4 (9.6GB), gemma4:e2b (7.2GB), gemma4:26b (18GB), gemma4:31b (20GB)

# --- Gemma 4 via OpenRouter (free tier) ---
# Uses the same OPENROUTER_API_KEY as Qwen. Select with --provider gemma-openrouter
# GEMMA_OPENROUTER_MODEL=google/gemma-4-26b-a4b-it
