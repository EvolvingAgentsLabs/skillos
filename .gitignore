# Environment files
.env
.claude/settings.local.json
.claude/history/
.claude/todos/
.qwen/

# Test-run debris: dynamic agent specs emitted by test_cognitive_pipeline
# and related tests into .claude/agents/. These are regenerated on every
# run — not checked in.
.claude/agents/Project_test*

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
venv/
.venv/
env/

# Workspace artifacts (runtime state, gitignored by design)
workspace/
projects/*/workspace/

# OS files
**/.DS_Store
Thumbs.db

# Editor / IDE
*.swp
*.swo
*~
.vscode/
.idea/

# Logs
*.log

# SkillOS package cache
.skillos-cache/

# Temporary files
*.tmp
*.temp

# Node (for skill packages with JS templates)
node_modules/
